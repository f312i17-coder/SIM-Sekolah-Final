rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Rule 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers (Phase 3)
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // School Settings
    match /settings/{docId} {
      allow read, write: if isSignedIn();
    }

    // Siswa (Students) Collection
    match /siswa/{siswaId} {
      allow read, write: if isSignedIn() && isValidId(siswaId);
    }

    // Nilai (Semester Grades) Collection
    match /nilai/{siswaId} {
      allow read, write: if isSignedIn() && isValidId(siswaId);
    }

    // Mutasi (Student Mutations)
    match /mutasi/{mutasiId} {
      allow read, write: if isSignedIn() && isValidId(mutasiId);
    }

    // Buku Induk
    match /bukuInduk/{siswaId} {
      allow read, write: if isSignedIn() && isValidId(siswaId);
    }

    // SPMB (New Student Registrations)
    match /spmb/{applicantId} {
      // Allow public creation for prospective student pendaftaran online, but restrict listing to authorized users
      allow create: if true;
      allow read, update, delete: if isSignedIn() && isValidId(applicantId);
    }

    // Arsip (Student Scan Folders)
    match /arsip/{arsipId} {
      allow read, write: if isSignedIn() && isValidId(arsipId);
    }
  }
}
